# Tests for the `ansi` package. Run with: espeto test packages/ansi/
import "ansi" only [
  red, green, blue, yellow, black, white,
  bright_red, bright_green,
  bg_red, bg_green, bg_bright_red, bg_bright_white,
  bold, dim, italic, underline, inverse, hidden, strikethrough
]

test "red wraps with code 31" do
  assert red("hi") == "\e[31mhi\e[0m"
end

test "green wraps with code 32" do
  assert green("hi") == "\e[32mhi\e[0m"
end

test "black wraps with code 30" do
  assert black("hi") == "\e[30mhi\e[0m"
end

test "white wraps with code 37" do
  assert white("hi") == "\e[37mhi\e[0m"
end

test "bright_red wraps with code 91" do
  assert bright_red("hi") == "\e[91mhi\e[0m"
end

test "bright_green wraps with code 92" do
  assert bright_green("hi") == "\e[92mhi\e[0m"
end

test "bg_red wraps with code 41" do
  assert bg_red("hi") == "\e[41mhi\e[0m"
end

test "bg_bright_red wraps with code 101" do
  assert bg_bright_red("hi") == "\e[101mhi\e[0m"
end

test "bg_bright_white wraps with code 107" do
  assert bg_bright_white("hi") == "\e[107mhi\e[0m"
end

test "bold wraps with code 1" do
  assert bold("hi") == "\e[1mhi\e[0m"
end

test "dim wraps with code 2" do
  assert dim("hi") == "\e[2mhi\e[0m"
end

test "italic wraps with code 3" do
  assert italic("hi") == "\e[3mhi\e[0m"
end

test "underline wraps with code 4" do
  assert underline("hi") == "\e[4mhi\e[0m"
end

test "inverse wraps with code 7" do
  assert inverse("hi") == "\e[7mhi\e[0m"
end

test "hidden wraps with code 8" do
  assert hidden("hi") == "\e[8mhi\e[0m"
end

test "strikethrough wraps with code 9" do
  assert strikethrough("hi") == "\e[9mhi\e[0m"
end

test "smart wrap reopens outer style after inner reset" do
  inner = bold("important")
  msg = "error: #{inner} happened"
  expected = "\e[31merror: \e[1mimportant\e[0m\e[31m happened\e[0m"
  assert red(msg) == expected
end

test "compose via pipe (red |> bold)" do
  result = "hi" |> red |> bold
  expected = "\e[1m\e[31mhi\e[0m\e[1m\e[0m"
  assert result == expected
end

test "preserves empty string" do
  assert red("") == "\e[31m\e[0m"
end

test "preserves multiline content" do
  assert red("a\nb") == "\e[31ma\nb\e[0m"
end

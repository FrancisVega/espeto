{
  "name": "vscode-espeto",
  "displayName": "Espeto",
  "description": "Language support for Espeto: syntax highlighting, hover docs, go-to-definition, completion, references, rename, outline, folding, signature help, and semantic tokens. Requires `espeto` installed globally (npm i -g espeto).",
  "version": "0.2.1",
  "publisher": "hisco",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:espeto"
  ],
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --platform=node --target=node18 --format=cjs --outfile=dist/extension.js --external:vscode",
    "typecheck": "tsc --noEmit"
  },
  "contributes": {
    "languages": [
      {
        "id": "espeto",
        "aliases": [
          "Espeto",
          "espeto"
        ],
        "extensions": [
          ".esp"
        ],
        "filenames": [
          "moraga.lock"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "espeto",
        "scopeName": "source.espeto",
        "path": "./syntaxes/espeto.tmLanguage.json"
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "espeto",
        "scopes": {
          "function": ["entity.name.function.espeto"],
          "function.defaultLibrary": ["support.function.builtin.espeto"],
          "parameter": ["variable.parameter.espeto"],
          "variable": ["variable.other.espeto"],
          "variable.defaultLibrary": ["variable.language.espeto"]
        }
      }
    ]
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.118.0",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3"
  }
}

{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "#{", "close": "}", "notIn": ["comment"] }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^.*\\bdo\\s*$|^.*[\\(\\[\\{]\\s*$",
    "decreaseIndentPattern": "^\\s*(end\\b|\\)|\\]|\\})"
  },
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*\\??"
}

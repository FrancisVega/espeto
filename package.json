{
	"name": "espeto-lang",
	"version": "0.1.0",
	"description": "Pipe-centric DSL for building CLIs.",
	"type": "module",
	"engines": {
		"node": ">=20"
	},
	"bin": {
		"espeto": "./dist/cli.js"
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"build": "esbuild src/cli.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/cli.js --banner:js='#!/usr/bin/env node' && chmod +x dist/cli.js",
		"prepublishOnly": "pnpm build && pnpm test",
		"espeto": "tsx src/cli.ts"
	},
	"packageManager": "pnpm@10.23.0",
	"devDependencies": {
		"@types/node": "^25.6.0",
		"esbuild": "^0.28.0",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5"
	}
}
